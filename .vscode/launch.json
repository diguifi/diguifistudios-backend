{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Diguifi.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/Diguifi.Api/bin/Debug/net10.0/Diguifi.Api.dll",
      "cwd": "${workspaceFolder}/src/Diguifi.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7080;http://localhost:5080"
      }
    }
  ]
}
