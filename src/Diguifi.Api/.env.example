# Copie para .env em desenvolvimento local.
# Em produção, use as mesmas chaves como variáveis de ambiente do provedor.

ConnectionStrings__Default=Server=(localdb)\mssqllocaldb;Database=DiguifiStudios;Trusted_Connection=True;MultipleActiveResultSets=true

Jwt__Issuer=Diguifi.Api
Jwt__Audience=Diguifi.Frontend
Jwt__SigningKey=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_KEY
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=30

Google__ClientId=
Google__ClientSecret=

Stripe__SecretKey=
Stripe__WebhookSecret=
Stripe__CliWebhookSecret=

Frontend__BaseUrl=https://diguifi.com

Swagger__Enabled=true
